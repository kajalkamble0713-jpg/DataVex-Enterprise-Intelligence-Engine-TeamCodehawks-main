# Runtime
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change_this_to_a_strong_secret_min_16_chars
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datavex

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/trigger-analysis
N8N_CALLBACK_URL=http://localhost:5000/api/webhook/n8n-callback
N8N_WEBHOOK_SECRET=replace_with_a_long_random_secret

# Agent Execution Mode
USE_DIRECT_AGENTS=true

# External APIs
CEREBRAS_API_KEY=replace_me
SERPAPI_API_KEY=
BROWSERLESS_API_KEY=
ALPHA_VANTAGE_KEY=

# Security / reliability tuning
ANALYZE_RATE_LIMIT_WINDOW_MS=60000
ANALYZE_RATE_LIMIT_MAX=5
ANALYZE_COOLDOWN_MINUTES=5
CACHE_TTL_SECONDS=86400
