    {
      "parameters": {
        "jsCode": "const parseSafe = (txt) => { try { return JSON.parse(txt); } catch { return txt; } };\nconst arbiterRaw = $node[\"Decision Arbiter\"].json.choices?.[0]?.message?.content || \"{}\";\nconst arbiter = parseSafe(arbiterRaw);\nconst verdict = typeof arbiter === \"object\" && arbiter.verdict ? arbiter.verdict : (arbiterRaw.includes(\"PURSUE\") ? \"PURSUE\" : \"IGNORE\");\nconst decisionReasoning = typeof arbiter === \"object\" && arbiter.decisionReasoning ? arbiter.decisionReasoning : arbiterRaw;\nconst outreachRaw = $node[\"Outreach Agent\"].json?.choices?.[0]?.message?.content || \"\";\nconst rejectionRaw = $node[\"Rejection Report\"].json?.choices?.[0]?.message?.content || \"\";\nconst bonusRaw = $node[\"Bonus Agent\"].json?.choices?.[0]?.message?.content || \"\";\nconst dossierRaw = $node[\"Researcher Agent\"].json?.choices?.[0]?.message?.content || \"{}\";\nconst trace = [\n  { agent: \"Researcher\", input: `domain: ${$json.domain}`, output: dossierRaw },\n  { agent: \"Market Analyst\", input: dossierRaw, output: $node[\"Market Analyst Agent\"].json?.choices?.[0]?.message?.content || \"\" },\n  { agent: \"Tech Debt\", input: $json.scraped_content, output: $node[\"Tech Debt Agent\"].json?.choices?.[0]?.message?.content || \"\" },\n  { agent: \"Financial\", input: $json.news_data, output: $node[\"Financial Pressure Agent\"].json?.choices?.[0]?.message?.content || \"\" },\n  { agent: \"Risk\", input: \"reject-first\", output: $node[\"Risk Agent\"].json?.choices?.[0]?.message?.content || \"\" },\n  { agent: \"Arbiter\", input: \"all analyses\", output: arbiterRaw }\n];\nreturn [{\n  json: {\n    jobId: $json.jobId,\n    status: \"completed\",\n    dossier: parseSafe(dossierRaw),\n    verdict,\n    decisionReasoning,\n    outreachMessage: verdict === \"PURSUE\" ? outreachRaw : rejectionRaw,\n    bonusContent: verdict === \"PURSUE\" ? parseSafe(bonusRaw) : { platform: \"Internal\", content: \"No bonus content for ignored leads.\" },\n    trace,\n    sourceData: {\n      scrapedContent: $json.scraped_content,\n      newsData: parseSafe($json.news_data)\n    }\n  }\n}];"
      },
