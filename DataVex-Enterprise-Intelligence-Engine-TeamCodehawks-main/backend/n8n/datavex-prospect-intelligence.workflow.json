        "jsonBody": "={\"model\":\"llama3.1-8b\",\"temperature\":0.1,\"messages\":[{\"role\":\"system\",\"content\":\"You are VP of Strategy at DataVex. Decide FINAL verdict as PURSUE or IGNORE using reject-first reasoning. Address each objection explicitly. Return valid JSON with fields: verdict and decisionReasoning.\"},{\"role\":\"user\",\"content\":\"Dossier: {{$node[\\\"Researcher Agent\\\"].json.choices[0].message.content}}\\nMarket: {{$node[\\\"Market Analyst Agent\\\"].json.choices[0].message.content}}\\nTech: {{$node[\\\"Tech Debt Agent\\\"].json.choices[0].message.content}}\\nFinancial: {{$node[\\\"Financial Pressure Agent\\\"].json.choices[0].message.content}}\\nObjections: {{$json.choices[0].message.content}}\"}]}",
